OPENAI_API_KEY=

# Primary LLM — Claude Sonnet (highest quality interview responses)
# When set, Claude is used over Groq/Gemini for all AI turns.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Secondary LLM — Groq (fast, free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tertiary fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Explicit override: anthropic | groq | gemini  (leave blank for auto-priority)
LLM_PROVIDER=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview

REDIS_URL=redis://localhost:6379

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=